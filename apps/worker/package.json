{
  "name": "@pcme/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist && find src -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' -o -name '*.d.ts.map' \\) -delete 2>/dev/null || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev": "dotenv -e ../../.env -- tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "dotenv -e ../../.env -- tsx scripts/worker-smoke.ts",
    "publishing:smoke": "dotenv -e ../../.env -- tsx scripts/publishing-smoke.ts",
    "publishing:smoke:wordpress": "dotenv -e ../../.env -- tsx scripts/publishing-smoke-wordpress.ts",
    "e2e:smoke": "dotenv -e ../../.env -- tsx scripts/e2e-smoke.ts",
    "publishing-history:smoke": "dotenv -e ../../.env -- tsx scripts/publishing-history-smoke.ts",
    "duplicate:smoke": "tsx scripts/duplicate-smoke.ts",
    "retry:smoke": "tsx scripts/retry-smoke.ts",
    "scheduler:smoke": "tsx scripts/scheduler-smoke.ts",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@pcme/ai": "workspace:*",
    "@pcme/database": "workspace:*",
    "@pcme/media": "workspace:*",
    "@pcme/plugin-ghost": "workspace:*",
    "@pcme/plugin-wordpress": "workspace:*",
    "@pcme/publishing": "workspace:*",
    "@pcme/seo": "workspace:*",
    "bullmq": "^5.79.2",
    "dotenv": "^16.4.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@pcme/api": "workspace:*",
    "@types/node": "^22.10.7",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
