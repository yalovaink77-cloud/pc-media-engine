# Local development only — not for production use.
# Copy to .env: cp .env.example .env

NODE_ENV=development

# PostgreSQL (matches docker-compose.yml)
POSTGRES_USER=pcme
POSTGRES_PASSWORD=pcme_dev
POSTGRES_DB=pcme_dev
DATABASE_URL=postgresql://pcme:pcme_dev@localhost:5432/pcme_dev

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Application (used by apps/api and apps/worker in later sprints)
API_PORT=3001
WORKER_CONCURRENCY=5
LOG_LEVEL=info
