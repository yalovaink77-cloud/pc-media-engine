{
  "name": "@pcme/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev": "dotenv -e ../../.env -- tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "dotenv -e ../../.env -- tsx src/scripts/worker-smoke.ts",
    "publishing:smoke": "dotenv -e ../../.env -- tsx src/scripts/publishing-smoke.ts",
    "publishing:smoke:wordpress": "dotenv -e ../../.env -- tsx src/scripts/publishing-smoke-wordpress.ts",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@pcme/database": "workspace:*",
    "@pcme/media": "workspace:*",
    "@pcme/plugin-wordpress": "workspace:*",
    "@pcme/publishing": "workspace:*",
    "bullmq": "^5.79.2",
    "dotenv": "^16.4.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
