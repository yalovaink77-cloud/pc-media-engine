    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "smoke": "tsx src/scripts/enrichment-smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
