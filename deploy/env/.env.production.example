# PC Media Engine — Production environment template (Sprint 48)
# Copy to deploy/env/.env.production and replace ALL placeholder secrets.
#
#   cp deploy/env/.env.production.example deploy/env/.env.production

NODE_ENV=production
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL (internal network — service name: postgres)
# ---------------------------------------------------------------------------
POSTGRES_USER=pcme
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pcme_prod
DATABASE_URL=postgresql://pcme:CHANGE_ME_STRONG_PASSWORD@postgres:5432/pcme_prod

# ---------------------------------------------------------------------------
# Redis (internal network — service name: redis)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
STORAGE_LOCAL_ROOT=/data/storage
PCME_DEFAULT_ORG_ID=REPLACE_WITH_SEEDED_ORG_UUID
PCME_DEFAULT_PROJECT_ID=REPLACE_WITH_SEEDED_PROJECT_UUID
PCME_DEFAULT_PROJECT_SLUG=piercingconnect
PUBLISHER_DRIVER=wordpress
PCME_AUTO_ENQUEUE_PROCESSING=true
PCME_AUTO_ENQUEUE_PUBLISHING=true
PCME_PUBLISHING_MAX_RETRIES=3
PCME_PUBLISHING_BACKOFF_MS=5000
AI_METADATA_PROVIDER=none

# ---------------------------------------------------------------------------
# Authentication & RBAC (recommended for production)
# ---------------------------------------------------------------------------
PCME_AUTH_ENABLED=true
PCME_JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
PCME_JWT_EXPIRES_IN=3600
PCME_API_KEYS=CHANGE_ME_LONG_RANDOM_API_KEY
PCME_DEFAULT_JWT_ROLE=operator
PCME_DEFAULT_API_KEY_ROLE=admin

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=5

# ---------------------------------------------------------------------------
# Dashboard (edge network — reaches API via internal Docker DNS)
# ---------------------------------------------------------------------------
DASHBOARD_PORT=3002
DASHBOARD_HOST=0.0.0.0
DASHBOARD_API_BASE_URL=http://api:3001
DASHBOARD_API_KEY=CHANGE_ME_LONG_RANDOM_API_KEY
DASHBOARD_RBAC_ENABLED=true
DASHBOARD_ROLE=admin

# ---------------------------------------------------------------------------
# WordPress publisher (when PUBLISHER_DRIVER=wordpress)
# Site URL only — do not append /wp-json (see plugins/wordpress/src/config.ts).
# Use a WordPress Application Password, not the account login password.
# ---------------------------------------------------------------------------
WORDPRESS_URL=https://example.com
WORDPRESS_USERNAME=pcme-bot
WORDPRESS_APP_PASSWORD=CHANGE_ME_APPLICATION_PASSWORD
# Optional: legacy alias for WORDPRESS_URL
# WORDPRESS_BASE_URL=https://example.com
# Optional: request timeout in ms (default 30000)
# WORDPRESS_REQUEST_TIMEOUT_MS=30000
# Optional handoff adapter defaults (draft remains default; forceDraft=true in worker bootstrap)
# WORDPRESS_DEFAULT_AUTHOR=
# WORDPRESS_DEFAULT_STATUS=draft

# ---------------------------------------------------------------------------
# Durable publishing worker (explicit run-once — NOT started by apps/worker)
# Run manually: pnpm publishing-worker:run-once
# See docs/deployment/durable-publishing-worker.md
# ---------------------------------------------------------------------------
# PCME_DURABLE_PUBLISHING_WORKER_ID=pcme-durable-publishing-worker
# PCME_DURABLE_PUBLISHING_LEASE_MS=60000
# PCME_DURABLE_PUBLISHING_MAX_ATTEMPTS=5
# Set true only when WordPress credentials above are configured; still draft-only.
# PCME_DURABLE_PUBLISHING_REGISTER_WORDPRESS=false

# ---------------------------------------------------------------------------
# Optional: Ghost publisher
# ---------------------------------------------------------------------------
# GHOST_API_URL=https://example.com
# GHOST_ADMIN_API_KEY=CHANGE_ME
