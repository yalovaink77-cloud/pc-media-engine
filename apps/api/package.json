{
  "name": "@pcme/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@pcme/database": "workspace:*",
    "@pcme/media": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.0",
    "bullmq": "^5.79.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
