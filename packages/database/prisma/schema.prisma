generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Organization & Project
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  plan      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  slug           String
  name           String
  domain         String?
  settings       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentItems         ContentItem[]
  assets               Asset[]
  publishingOutbox     PublishingOutboxEntry[]
  publishRecords       PublishRecord[]
  aiJobs               AiJob[]
  auditLogEntries      AuditLogEntry[]
  analyticsSnapshots   AnalyticsSnapshot[]
  ingestionSources     IngestionSource[]
  ingestionJobs        IngestionJob[]
  processingJobs       ProcessingJob[]
  publishedContent     PublishedContent[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("projects")
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

enum ContentState {
  idea
  researching
  drafted
  reviewing
  approved
  published
  refresh_needed
  archived
}

enum ContentType {
  guide
  faq
  aftercare_card
  printable
  affiliate_section
  bmc_block
  social_post
  newsletter
  video_script
}

model ContentItem {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  projectId      String       @map("project_id")
  type           ContentType
  state          ContentState @default(idea)
  revision       Int          @default(1)
  title          String?
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  project            Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions           ContentVersion[]
  seoProfiles        SeoProfile[]
  publishingOutbox   PublishingOutboxEntry[]
  publishRecords     PublishRecord[]
  aiJobs             AiJob[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@index([projectId])
  @@index([organizationId])
  @@index([projectId, state])
  @@index([projectId, deletedAt])
  @@map("content_items")
}

model ContentVersion {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  projectId          String   @map("project_id")
  contentItemId      String   @map("content_item_id")
  blockSchemaVersion Int      @default(1) @map("block_schema_version")
  body               Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")

  contentItem        ContentItem             @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  publishingOutbox   PublishingOutboxEntry[]
  publishRecords     PublishRecord[]

  @@index([contentItemId])
  @@index([projectId])
  @@map("content_versions")
}

model SeoProfile {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  projectId       String   @map("project_id")
  contentItemId   String   @map("content_item_id")
  focusKeyword    String?  @map("focus_keyword")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  slug            String?
  schema          Json?
  contentScore    Float?   @map("content_score")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([contentItemId])
  @@index([projectId])
  @@map("seo_profiles")
}

// ---------------------------------------------------------------------------
// Media — metadata domain (Sprint 3)
// ---------------------------------------------------------------------------

enum AssetStatus {
  pending
  processing
  ready
  failed
}

enum MediaSourceType {
  upload
  external_url
  ai_generated
  stock
  import
  unknown
}

model Asset {
  id                String      @id @default(cuid())
  organizationId    String      @map("organization_id")
  projectId         String      @map("project_id")
  ingestionJobId    String?     @map("ingestion_job_id")
  filename          String
  originalFilename  String      @map("original_filename")
  mimeType          String      @map("mime_type")
  storageProvider   String      @map("storage_provider")
  storageKey        String      @map("storage_key")
  sizeBytes         Int         @map("size_bytes")
  checksum          String?
  checksumAlgorithm String      @default("sha256") @map("checksum_algorithm")
  altText           String?     @map("alt_text")
  tags              String[]    @default([])
  usageRights       String?     @map("usage_rights")
  status            AssetStatus @default(pending)
  deletedAt         DateTime?   @map("deleted_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ingestionJob     IngestionJob?     @relation(fields: [ingestionJobId], references: [id], onDelete: SetNull)
  mediaSources     MediaSource[]
  metadataRecords  MetadataRecord[]
  processingJobs   ProcessingJob[]
  publishedContent PublishedContent[]

  @@unique([projectId, storageKey])
  @@index([projectId])
  @@index([organizationId])
  @@index([ingestionJobId])
  @@index([projectId, deletedAt])
  @@index([projectId, status])
  @@index([projectId, mimeType])
  @@map("assets")
}

model MediaSource {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  projectId      String          @map("project_id")
  assetId        String          @map("asset_id")
  sourceType     MediaSourceType @map("source_type")
  sourceUrl      String?         @map("source_url")
  sourceLabel    String?         @map("source_label")
  createdAt      DateTime        @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([projectId])
  @@index([projectId, sourceType])
  @@map("media_sources")
}

model MetadataRecord {
  id             String   @id @default(cuid())
  organizationId String @map("organization_id")
  projectId      String   @map("project_id")
  assetId        String   @map("asset_id")
  namespace      String
  key            String
  value          Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, namespace, key])
  @@index([projectId])
  @@index([assetId, namespace])
  @@map("metadata_records")
}

// ---------------------------------------------------------------------------
// Ingestion — intent and tracking domain (Sprint 4)
// ---------------------------------------------------------------------------

enum IngestionSourceType {
  local_folder
  http_url
  youtube
  rss
  s3_placeholder
  manual
}

enum IngestionStatus {
  pending
  running
  completed
  failed
  canceled
}

model IngestionSource {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  projectId      String              @map("project_id")
  sourceType     IngestionSourceType @map("source_type")
  sourceUri      String              @map("source_uri")
  sourceLabel    String?             @map("source_label")
  isEnabled      Boolean             @default(true) @map("is_enabled")
  config         Json                @default("{}")
  deletedAt      DateTime?           @map("deleted_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ingestionJobs IngestionJob[]

  @@unique([projectId, sourceType, sourceUri])
  @@index([projectId])
  @@index([organizationId])
  @@index([projectId, deletedAt])
  @@index([projectId, sourceType])
  @@map("ingestion_sources")
}

model IngestionJob {
  id                   String              @id @default(cuid())
  organizationId       String              @map("organization_id")
  projectId            String              @map("project_id")
  ingestionSourceId    String?             @map("ingestion_source_id")
  status               IngestionStatus     @default(pending)
  sourceType           IngestionSourceType @map("source_type")
  sourceUri            String              @map("source_uri")
  sourceIdentifier     String?             @map("source_identifier")
  discoveredAssetCount Int                 @default(0) @map("discovered_asset_count")
  importedAssetCount   Int                 @default(0) @map("imported_asset_count")
  failureReason        String?             @map("failure_reason")
  startedAt            DateTime?           @map("started_at")
  completedAt          DateTime?           @map("completed_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ingestionSource IngestionSource? @relation(fields: [ingestionSourceId], references: [id], onDelete: SetNull)
  assets          Asset[]

  @@index([projectId])
  @@index([organizationId])
  @@index([projectId, status])
  @@index([ingestionSourceId])
  @@index([projectId, createdAt])
  @@map("ingestion_jobs")
}

// ---------------------------------------------------------------------------
// Processing — intent and artifact domain (Sprint 5)
// ---------------------------------------------------------------------------

enum ProcessingType {
  metadata_extract
  thumbnail
  waveform
  transcript
  preview
  ai_analysis
}

enum ProcessingStatus {
  pending
  queued
  running
  completed
  failed
  cancelled
}

enum ArtifactType {
  thumbnail
  transcript
  waveform
  preview
  metadata
}

model ProcessingJob {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  projectId      String          @map("project_id")
  assetId        String          @map("asset_id")
  processingType ProcessingType  @map("processing_type")
  status         ProcessingStatus @default(pending)
  priority       Int             @default(0)
  retryCount     Int             @default(0) @map("retry_count")
  requestedAt    DateTime        @default(now()) @map("requested_at")
  startedAt      DateTime?       @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  failureReason  String?         @map("failure_reason")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  project             Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset               Asset                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  processingArtifacts ProcessingArtifact[]
  attempts            ProcessingJobAttempt[]

  @@unique([assetId, processingType])
  @@index([projectId])
  @@index([organizationId])
  @@index([assetId])
  @@index([projectId, status])
  @@index([projectId, processingType])
  @@index([status, priority])
  @@map("processing_jobs")
}

model ProcessingJobAttempt {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  projectId       String           @map("project_id")
  processingJobId String           @map("processing_job_id")
  attemptNumber   Int              @map("attempt_number")
  status          ProcessingStatus @default(pending)
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  failureReason   String?          @map("failure_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  processingJob ProcessingJob @relation(fields: [processingJobId], references: [id], onDelete: Cascade)

  @@unique([processingJobId, attemptNumber])
  @@index([processingJobId])
  @@index([projectId])
  @@map("processing_job_attempts")
}

model ProcessingArtifact {
  id                    String       @id @default(cuid())
  organizationId        String       @map("organization_id")
  projectId             String       @map("project_id")
  processingJobId       String       @map("processing_job_id")
  assetId               String       @map("asset_id")
  artifactType          ArtifactType @map("artifact_type")
  mimeType              String       @map("mime_type")
  storageKeyPlaceholder String       @map("storage_key_placeholder")
  storageKey            String?      @map("storage_key")
  checksum              String?
  sizeBytes             Int?         @map("size_bytes")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  processingJob ProcessingJob @relation(fields: [processingJobId], references: [id], onDelete: Cascade)

  @@unique([processingJobId, artifactType])
  @@index([processingJobId])
  @@index([assetId])
  @@index([projectId])
  @@map("processing_artifacts")
}

// ---------------------------------------------------------------------------
// Publishing
// ---------------------------------------------------------------------------

enum OutboxStatus {
  pending
  processing
  succeeded
  failed
  cancelled
}

enum OutboxAction {
  create
  update
}

model PublishingOutboxEntry {
  id                String       @id @default(cuid())
  organizationId    String       @map("organization_id")
  projectId         String       @map("project_id")
  contentItemId     String       @map("content_item_id")
  contentVersionId  String       @map("content_version_id")
  channel           String
  action            OutboxAction
  idempotencyKey    String       @unique @map("idempotency_key")
  status            OutboxStatus @default(pending)
  payload           Json?
  attemptCount      Int          @default(0) @map("attempt_count")
  maxAttempts       Int          @default(5) @map("max_attempts")
  lastAttemptAt     DateTime?    @map("last_attempt_at")
  nextRetryAt       DateTime?    @map("next_retry_at")
  providerResponse  Json?        @map("provider_response")
  errorLog          String?      @map("error_log")
  externalId        String?      @map("external_id")
  publishedUrl      String?      @map("published_url")
  createdBy         Json         @default("{}") @map("created_by")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentItem    ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentVersion ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([contentItemId])
  @@map("publishing_outbox_entries")
}

model PublishRecord {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  projectId        String   @map("project_id")
  contentItemId    String   @map("content_item_id")
  contentVersionId String   @map("content_version_id")
  channel          String
  externalId       String   @map("external_id")
  url              String
  publishedAt      DateTime @map("published_at")
  createdAt        DateTime @default(now()) @map("created_at")

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentItem    ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentVersion ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([contentItemId])
  @@index([projectId, channel])
  @@map("publish_records")
}

enum PublishedContentStatus {
  draft
  published
  failed
}

model PublishedContent {
  id             String                 @id @default(cuid())
  organizationId String                 @map("organization_id")
  projectId      String                 @map("project_id")
  assetId        String                 @map("asset_id")
  slug           String
  publisher      String
  externalId     String                 @map("external_id")
  url            String
  status         PublishedContentStatus
  publishedAt    DateTime               @map("published_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([projectId])
  @@index([publisher])
  @@index([publishedAt])
  @@index([projectId, assetId])
  @@index([publisher, externalId])
  @@index([projectId, publisher, slug])
  @@map("published_content")
}

// ---------------------------------------------------------------------------
// AI
// ---------------------------------------------------------------------------

enum AiJobStatus {
  pending
  running
  succeeded
  failed
}

model AiJob {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  projectId      String      @map("project_id")
  contentItemId  String?     @map("content_item_id")
  task           String
  provider       String
  model          String
  status         AiJobStatus @default(pending)
  inputTokens    Int?        @map("input_tokens")
  outputTokens   Int?        @map("output_tokens")
  durationMs     Int?        @map("duration_ms")
  error          String?
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentItem ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, createdAt])
  @@map("ai_jobs")
}

// ---------------------------------------------------------------------------
// Audit (append-only)
// ---------------------------------------------------------------------------

model AuditLogEntry {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  actor          Json
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_log_entries")
}

// ---------------------------------------------------------------------------
// Analytics
// ---------------------------------------------------------------------------

model AnalyticsSnapshot {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  projectId      String   @map("project_id")
  contentItemId  String?  @map("content_item_id")
  publishedUrl   String?  @map("published_url")
  metrics        Json?
  capturedAt     DateTime @map("captured_at")
  createdAt      DateTime @default(now()) @map("created_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentItem ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([projectId, capturedAt])
  @@map("analytics_snapshots")
}
