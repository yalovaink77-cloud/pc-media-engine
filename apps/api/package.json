{
  "name": "@pcme/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist && find src -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.js.map' -o -name '*.d.ts.map' \\) -delete 2>/dev/null || true",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "publishing-api:smoke": "tsx scripts/publishing-api-smoke.ts",
    "dashboard-api:smoke": "tsx scripts/dashboard-api-smoke.ts",
    "metrics:smoke": "tsx scripts/metrics-smoke.ts",
    "beta:smoke": "tsx scripts/beta-smoke.ts",
    "auth:smoke": "tsx scripts/auth-smoke.ts",
    "queue:smoke": "tsx scripts/queue-smoke.ts",
    "publisher-management:smoke": "tsx scripts/publisher-management-smoke.ts",
    "jobs:smoke": "tsx scripts/jobs-smoke.ts",
    "assets:smoke": "tsx scripts/assets-smoke.ts",
    "composer:smoke": "tsx scripts/composer-smoke.ts",
    "publish-workflow:smoke": "tsx scripts/publish-workflow-smoke.ts",
    "bulk-publish:smoke": "tsx scripts/bulk-publish-smoke.ts",
    "calendar:smoke": "tsx scripts/calendar-smoke.ts",
    "provider-config:smoke": "tsx scripts/provider-config-smoke.ts",
    "rbac:smoke": "tsx scripts/rbac-smoke.ts",
    "audit:smoke": "tsx scripts/audit-smoke.ts",
    "notifications:smoke": "tsx scripts/notifications-smoke.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@pcme/ai": "workspace:*",
    "@pcme/database": "workspace:*",
    "@pcme/media": "workspace:*",
    "@pcme/plugin-ghost": "workspace:*",
    "@pcme/plugin-wordpress": "workspace:*",
    "@pcme/publisher-sdk": "workspace:*",
    "@pcme/seo": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.0",
    "bullmq": "^5.79.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
