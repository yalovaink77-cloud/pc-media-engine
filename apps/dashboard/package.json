{
  "name": "@pcme/dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:ops": "tsx scripts/dashboard-ops-smoke.ts",
    "smoke:publishers": "tsx scripts/publisher-management-smoke.ts",
    "smoke:jobs": "tsx scripts/jobs-smoke.ts",
    "smoke:assets": "tsx scripts/assets-smoke.ts",
    "smoke:composer": "tsx scripts/composer-smoke.ts",
    "publish-workflow:smoke": "tsx scripts/publish-workflow-smoke.ts"
  },
  "dependencies": {
    "fastify": "^4.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
